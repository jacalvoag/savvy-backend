# Savvy Backend - Environment Variables Template

# Application
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
# Para desarrollo local: apuntar a savvy-infra levantado
# Para producción: apuntar a Managed Database o mismo servidor
DATABASE_URL="postgresql://savvy_app:changeme@localhost:5432/savvy"

# JWT Authentication
JWT_SECRET=super-secret-change-in-production-min-32-chars

# External APIs (Optional)
BREVO_API_KEY=
EXCHANGERATE_API_KEY=

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Prisma
# Uncomment para ver queries SQL en consola
# DATABASE_LOGGING=true